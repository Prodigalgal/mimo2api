PORT=8080
MIMO2API_DATABASE_FILE=/var/lib/mimo2api/mimo2api.sqlite
MIMO2API_CONFIG_FILE=/var/lib/mimo2api/config.json
MIMO2API_DATA_DIR=/var/lib/mimo2api

MIMO2API_ADMIN_PASSWORD=change-me
MIMO2API_API_KEYS=sk-xxx
MIMO2API_COMPACTION_KEY=change-me-to-a-long-random-secret

MIMO2API_REQUEST_TIMEOUT_MS=600000
MIMO2API_STREAM_IDLE_TIMEOUT_MS=180000
MIMO2API_SSE_HEARTBEAT_MS=10000
MIMO2API_MAX_UPLOAD_BYTES=26214400

MIMO2API_RENEW_ENABLED=true
MIMO2API_RENEW_CONCURRENCY=1
MIMO2API_RENEW_INTERVAL_SECONDS=21600
MIMO2API_RENEW_INITIAL_SPREAD_SECONDS=3600
MIMO2API_RENEW_MANUAL_SPREAD_SECONDS=900
MIMO2API_RENEW_LEASE_SECONDS=900
MIMO2API_RENEW_POLL_SECONDS=30
MIMO2API_RENEW_GAP_MS=3000

MIMO2API_TEMP_MAIL_API_BASE=https://apimail.example.com
MIMO2API_TEMP_MAIL_ADMIN_PASSWORD=your-admin-pass
MIMO2API_TEMP_MAIL_SITE_PASSWORD=
MIMO2API_TEMP_MAIL_DOMAIN=

MIMO2API_CAPTCHA_OCR_URL=http://127.0.0.1:8090
MIMO2API_CAPTCHA_AI_ENABLED=false
MIMO2API_CAPTCHA_AI_API_BASE=https://openai-compatible.example.com
MIMO2API_CAPTCHA_AI_API_KEY=sk-xxx
MIMO2API_CAPTCHA_AI_MODEL=grok
MIMO2API_CAPTCHA_AI_TIMEOUT=90

MIMO2API_PROXY_ENABLED=false
MIMO2API_PROXY_SUB_URL=https://proxy.example.com/sub?token=YOUR_TOKEN
MIMO2API_PROXY_LISTEN_PORT=17890
MIMO2API_PROXY_CONNECT_RETRIES=5
MIMO2API_PROXY_FETCH_SUB_EACH_TIME=true
